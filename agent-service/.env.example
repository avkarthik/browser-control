# ─────────────────────────────────────────────────────────────
# agent-service/.env.example — for the FastAPI service
# Copy to `.env` and fill in real values. This file is safe to commit.
# See docs/environment.md for the full reference.
# All values map 1:1 to fields in app/config.py (Settings).
# ─────────────────────────────────────────────────────────────

# ── WAHA (WhatsApp HTTP API) ──────────────────────────────
# Base URL of your WAHA instance.
WAHA_URL=http://192.168.2.152:3001
# X-Api-Key header value. Leave empty if WAHA auth is disabled.
WAHA_API_KEY=
# Chat to send messages to. @g.us = group, @c.us = direct chat.
WHATSAPP_CHAT_ID=120363407334128082@g.us
# WAHA session name.
WHATSAPP_SESSION=default

# ── LLM providers ─────────────────────────────────────────
# Ollama HTTP endpoint (only if using provider=ollama).
OLLAMA_HOST=http://192.168.2.152:11434
OLLAMA_DEFAULT_MODEL=gemma4

# Google AI key — required for Gemini + fallback.
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# DeepSeek key — only if using provider=deepseek.
# Get one at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenRouter key — only if using provider=openrouter.
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Agent defaults ────────────────────────────────────────
DEFAULT_PROVIDER=gemini
DEFAULT_MAX_STEPS=25
# How often the on_step_end hook pauses and sends a consolidated WhatsApp message.
PAUSE_EVERY_N_STEPS=6
# Uvicorn listen port. Also used by docker-compose.yml (${PORT:-8765}).
PORT=8765

# ── Per-provider default models ───────────────────────────
GEMINI_DEFAULT=gemini-3.1-flash-lite
DEEPSEEK_DEFAULT=DeepSeek-V4-Flash
OPENROUTER_DEFAULT=nvidia/nemotron-nano-12b-v2-vl:free

# ── Fallback ──────────────────────────────────────────────
# Gemini model used by get_fallback_llm() when a non-Gemini provider fails.
GEMINI_FALLBACK_MODEL=gemma-4-31b-it