# ─────────────────────────────────────────────────────────────
# Root .env.example — for sample-agent.py
# Copy to `.env` and fill in real values. This file is safe to commit.
# See docs/environment.md for the full reference.
# ─────────────────────────────────────────────────────────────

# Google AI API key — required for the default Gemini provider and for the
# Gemini fallback used by non-Gemini providers.
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# DeepSeek API key — only needed if you run: python sample-agent.py deepseek
# Get one at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenRouter API key — only needed if you run: python sample-agent.py openrouter
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NOTE: Ollama needs no env var. The host is hardcoded as
# OLLAMA_HOST = "http://127.0.0.1:11434" in sample-agent.py.
# Edit that constant to point at a different host.